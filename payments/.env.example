# Copy this file to .env and fill in your sandbox credentials.
# Sign up at https://sandbox.pesapal.com to get Consumer Key + Secret (free).

PESAPAL_CONSUMER_KEY=your_sandbox_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_sandbox_consumer_secret_here

# "sandbox" for testing, "production" for live
PESAPAL_ENV=sandbox

# URL Pesapal will POST payment notifications to (must be publicly reachable).
# For local dev use ngrok: ngrok http 5000  → paste the https URL below.
IPN_URL=https://your-ngrok-id.ngrok.io/api/pay/ipn

# Django base URL (for the IPN handler to call back and update order status)
DJANGO_BASE=http://127.0.0.1:8000

# Shared secret between Node payments service and Django for the internal webhook
INTERNAL_WEBHOOK_KEY=dev-internal-key
