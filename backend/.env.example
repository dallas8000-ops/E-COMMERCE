# Copy to .env and set a strong secret key
DJANGO_SECRET_KEY=replace-with-strong-secret-key

# --- Email ---
#
# Default (no DJANGO_EMAIL_BACKEND): console backend — no real mail; Contact page shows a dev notice.
#
# --- Gmail (SMTP) ---
# 1. Use a Google Account with 2-Step Verification turned on.
# 2. Google Account → Security → How you sign in to Google → App passwords.
#    Create an app password (choose “Mail” / device “Other” → e.g. “Kistie Store”).
# 3. Copy the 16-character password (you may paste with or without spaces — Django strips fine).
# 4. Put REAL values only in backend/.env (never commit .env — it is gitignored).
#
# Tip: DJANGO_DEFAULT_FROM_EMAIL should usually match EMAIL_HOST_USER so Gmail accepts the sender.

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=youraccount@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=youraccount@gmail.com

# Where storefront contact inquiries are delivered (often same as your Gmail).
CONTACT_RECIPIENT_EMAIL=youraccount@gmail.com
