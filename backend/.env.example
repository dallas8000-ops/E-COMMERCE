# Copy to .env and set a strong secret key
DJANGO_SECRET_KEY=replace-with-strong-secret-key
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=replace-with-16-char-gmail-app-password
EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=your-email@gmail.com
CONTACT_RECIPIENT_EMAIL=your-email@gmail.com
