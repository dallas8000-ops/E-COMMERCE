# Copy this file to `.env` in THIS folder (`backend/.env`) and fill in real values.
# NEVER commit `backend/.env` — it is gitignored.
# NEVER put real Gmail app passwords in `.env.example` — this file is public on GitHub.

DJANGO_SECRET_KEY=replace-with-strong-secret-key

# --- Email ---
#
# Omit DJANGO_EMAIL_BACKEND (or use console) → mail prints in terminal; Contact page shows dev notice.
# For real Gmail delivery, use SMTP below in your private `backend/.env` only.

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youraccount@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DJANGO_DEFAULT_FROM_EMAIL=youraccount@gmail.com
CONTACT_RECIPIENT_EMAIL=youraccount@gmail.com
