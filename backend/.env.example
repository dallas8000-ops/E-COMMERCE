# Copy this file to `.env` in THIS folder (`backend/.env`) and fill in real values.
# NEVER commit `backend/.env` — it is gitignored.
# NEVER put real Gmail app passwords in `.env.example` — this file is public on GitHub.

DJANGO_SECRET_KEY=replace-with-strong-secret-key

# Omit DJANGO_EMAIL_BACKEND → console backend (dev notice on Contact page).
# For Gmail: uncomment SMTP lines below ONLY in your private `backend/.env`.

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-account@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DJANGO_DEFAULT_FROM_EMAIL=your-account@gmail.com
CONTACT_RECIPIENT_EMAIL=your-account@gmail.com
